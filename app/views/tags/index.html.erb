<% content_for :title, t(".title") %>

<header class="page-header">
  <div>
    <h1><%= t(".title") %></h1>
    <p class="muted"><%= t(".lede") %></p>
  </div>
  <%= link_to new_tag_path, class: "btn" do %>
    <%= icon("plus") %>
    <%= t(".new") %>
  <% end %>
</header>

<div class="page-toolbar">
  <%= form_with url: tags_path, method: :get, class: "page-search" do |form| %>
    <%= icon("search") %>
    <% if @showing_archived %><%= form.hidden_field :archived, value: "1" %><% end %>
    <%= form.search_field :q, value: params[:q], placeholder: t("common.search_by_name"),
          autocomplete: "off", "aria-label": t(".search_aria") %>
  <% end %>

  <% if @showing_archived %>
    <%= link_to t("common.view_active_feminine"), tags_path, class: "muted" %>
  <% else %>
    <%= link_to t("common.view_archived_feminine"), tags_path(archived: "1"), class: "muted" %>
  <% end %>
</div>

<% if @tags.any? %>
  <table class="data-table">
    <thead>
      <tr>
        <th><%= t("common.labels.name") %></th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <%= render partial: "tags/tag", collection: @tags, as: :tag %>
    </tbody>
  </table>
<% elsif params[:q].present? %>
  <div class="empty-state">
    <p><%= t(".empty.search", query: params[:q]) %></p>
  </div>
<% elsif @showing_archived %>
  <div class="empty-state">
    <p><%= t(".empty.archived") %></p>
  </div>
<% else %>
  <div class="empty-state">
    <%= icon("tags", class: "icon--lg") %>
    <h2><%= t(".empty.title") %></h2>
    <p class="muted">
      <%= t(".empty.description") %>
    </p>
    <%= link_to new_tag_path, class: "btn" do %>
      <%= icon("plus") %>
      <%= t(".empty.cta") %>
    <% end %>
  </div>
<% end %>
