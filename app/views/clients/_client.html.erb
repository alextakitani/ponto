<%# Uma linha densa da lista de clientes. Colunas numéricas em tabular-nums.
    Menu ⋮ (<details> + Stimulus menu_controller p/ fechar ao clicar fora / Escape —
    light-dismiss; o <details> ainda funciona sem JS). O summary é o único botão
    compacto sem label visível — por isso o aria-label (Q80). %>
<tr id="<%= dom_id(client) %>">
  <td>
    <%= link_to client.name, edit_client_path(client) %>
    <% if client.archived? %><span class="tag-badge">arquivado</span><% end %>
  </td>
  <td><%= client.currency %></td>
  <td class="data-table__num tabular-nums">
    <%= client_rate(client) %>
  </td>
  <td class="data-table__actions">
    <details class="row-menu" data-controller="menu">
      <summary class="btn btn--quiet" aria-label="Ações de <%= client.name %>"><%= icon("ellipsis-vertical") %></summary>
      <div class="row-menu__items">
        <%= link_to edit_client_path(client), class: "btn btn--quiet" do %>
          <%= icon("pencil") %>
          Editar
        <% end %>

        <% if client.archived? %>
          <%= button_to client_archival_path(client), method: :delete, class: "btn btn--quiet" do %>
            <%= icon("archive-restore") %>
            Desarquivar
          <% end %>
        <% else %>
          <%= button_to client_archival_path(client), class: "btn btn--quiet" do %>
            <%= icon("archive") %>
            Arquivar
          <% end %>
        <% end %>

        <%# Hard-delete com confirmação (Q7). A Fatia 2.3 adiciona `restrict` quando
            Project nascer — por ora não há dependentes, então deletar é seguro. %>
        <%= button_to client_path(client), method: :delete,
              class: "btn btn--danger",
              data: { turbo_confirm: "Deletar “#{client.name}” definitivamente? Esta ação não pode ser desfeita." } do %>
          <%= icon("trash-2") %>
          Deletar
        <% end %>
      </div>
    </details>
  </td>
</tr>
