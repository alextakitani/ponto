<div id="tracker_entries" class="tracker-list">
  <% if day_groups.any? %>
    <% day_groups.each do |day_group| %>
      <%= render "home/day_group", day_group: day_group %>
    <% end %>
  <% else %>
    <div class="empty-state">
      <%= icon("timer", class: "icon--lg") %>
      <h2><%= t("tracker.empty.title") %></h2>
      <p class="muted"><%= t("tracker.empty.description") %></p>
    </div>
  <% end %>
</div>

<div id="tracker_entries_load_more" class="tracker-load-more">
  <% if defined?(@tracker_has_more) && @tracker_has_more %>
    <%= link_to tracker_entries_path(tracker_next_page_params),
          class: "btn btn--quiet",
          data: { turbo_stream: true } do %>
      <%= t("tracker.load_more") %>
    <% end %>
  <% end %>
</div>
