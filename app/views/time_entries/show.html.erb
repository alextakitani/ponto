<% content_for :title, "Entrada" %>

<header class="page-header">
  <div>
    <h1><%= @time_entry.description.presence || "Sem descrição" %></h1>
    <p class="muted">
      <%= l(@time_entry.started_at, format: :short) %>
      <% if @time_entry.ended_at? %>
        · <%= l(@time_entry.ended_at, format: :short) %>
      <% else %>
        · Rodando
      <% end %>
    </p>
  </div>
</header>

<dl class="details-list">
  <div>
    <dt>Projeto</dt>
    <dd><%= @time_entry.project_id || "Sem projeto" %></dd>
  </div>
  <div>
    <dt>Task</dt>
    <dd><%= @time_entry.task_id || "Sem task" %></dd>
  </div>
  <div>
    <dt>Faturável</dt>
    <dd><%= @time_entry.billable? ? "Sim" : "Não" %></dd>
  </div>
</dl>
