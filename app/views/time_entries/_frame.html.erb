<%= turbo_frame_tag time_entry do %>
  <article id="<%= dom_id(time_entry) %>" class="tracker-entry <%= "tracker-entry--running" unless time_entry.ended_at? %>"
      data-entry-id="<%= time_entry.id %>" data-running="<%= !time_entry.ended_at? %>">
    <div class="tracker-entry__main">
      <div class="tracker-entry__summary">
        <%# Descrição longa trunca com ellipsis (CSS). Pra ler inteira: title =
            tooltip nativo no mouseover (desktop); tabindex = tap/Tab foca o span
            e o :focus desfaz a truncagem (mobile, onde title não existe); o 2º
            clique reverte (focus-toggle). Sem descrição, nada disso é renderizado. %>
        <%= tag.span tracker_entry_description(time_entry), class: "tracker-entry__description",
              title: time_entry.description.presence,
              tabindex: ("0" if time_entry.description.present?),
              data: (if time_entry.description.present?
                       { controller: "focus-toggle",
                         action: "pointerdown->focus-toggle#pointerdown click->focus-toggle#click" }
                     end) %>
        <span class="tracker-entry__project">
          <% if time_entry.project %>
            <span class="project-dot" style="background-color: <%= time_entry.project.color %>" aria-hidden="true"></span>
          <% end %>
          <span class="tracker-entry__project-name"><%= tracker_entry_project_name(time_entry) %></span>
        </span>
        <span class="tracker-entry__range muted tabular-nums"><%= tracker_entry_time_range(time_entry) %></span>
      </div>
      <% if tracker_entry_tags(time_entry).any? %>
        <div class="tracker-entry__tags">
          <% tracker_entry_tags(time_entry).each do |tag| %>
            <span class="tag-badge"><%= tag.name %></span>
          <% end %>
          <% if local_assigns[:overlapping_ids]&.include?(time_entry.id) %>
            <span class="tag-badge tag-badge--danger" title="<%= t('time_entries.overlap_badge_title') %>">
              <%= t('time_entries.overlap_badge') %>
            </span>
          <% end %>
        </div>
      <% elsif local_assigns[:overlapping_ids]&.include?(time_entry.id) %>
        <div class="tracker-entry__tags">
          <span class="tag-badge tag-badge--danger" title="<%= t('time_entries.overlap_badge_title') %>">
            <%= t('time_entries.overlap_badge') %>
          </span>
        </div>
      <% end %>
    </div>

    <div class="tracker-entry__actions">
      <%# O € por entry saiu da linha (decisão do dono 07/07): valor mora no total
          do dia e aqui, como tooltip do decorrido (só entry parada — a rodando
          teria um valor defasado). title = mouseover no desktop; tabindex = o tap
          foca no mobile e o :focus desenha o tooltip via attr(title) (CSS puro,
          mesmo padrão da descrição truncada); o 2º clique reverte (focus-toggle). %>
      <% billable_tooltip = (time_entry.billable_amount&.format if time_entry.ended_at?) %>
      <%= tag.span class: "tracker-entry__duration tabular-nums",
            title: billable_tooltip, tabindex: ("0" if billable_tooltip),
            data: (if billable_tooltip
                     { controller: "focus-toggle",
                       action: "pointerdown->focus-toggle#pointerdown click->focus-toggle#click" }
                   end) do %>
        <% if time_entry.ended_at? %>
          <%= tracker_duration(time_entry.duration_seconds) %>
        <% else %>
          <span data-controller="stopwatch" data-stopwatch-started-at-value="<%= time_entry.started_at.iso8601 %>">
            <%= tracker_duration(0) %>
          </span>
        <% end %>
      <% end %>

      <details class="row-menu" data-controller="menu">
        <summary class="btn btn--quiet btn--sm" aria-label="<%= t("time_entries.entry.actions_label", description: tracker_entry_description(time_entry)) %>">
          <%= icon("ellipsis-vertical") %>
        </summary>
        <div class="row-menu__items">
          <%= link_to edit_time_entry_path(time_entry), class: "btn btn--quiet", data: { turbo_frame: dom_id(time_entry) } do %>
            <%= icon("pencil") %>
            <%= t("common.actions.edit") %>
          <% end %>

          <% if time_entry.ended_at? %>
            <%# Duplicar (Q47): re-dispara este entry num timer novo rodando AGORA. %>
            <%= button_to time_entry_duplicate_path(time_entry), class: "btn btn--quiet",
                  params: (params[:page].present? ? { page: params[:page] } : {}),
                  data: { turbo_frame: "timer_bar" } do %>
              <%= icon("play") %>
              <%= t("time_entries.entry.duplicate") %>
            <% end %>

            <%# Dividir (Q48): quebra o entry em dois no ponto de corte (default = meio). %>
            <details class="row-menu__split">
              <summary class="btn btn--quiet">
                <%= icon("scissors") %>
                <%= t("time_entries.entry.split") %>
              </summary>
              <%= form_with url: time_entry_split_path(time_entry), data: { turbo_frame: "tracker_entries" },
                    class: "row-menu__split-form" do %>
                <label for="split_cut_<%= time_entry.id %>" class="muted"><%= t("time_entries.entry.cut_at") %></label>
                <input type="datetime-local" id="split_cut_<%= time_entry.id %>"
                       name="split[cut]" value="<%= tracker_split_default(time_entry) %>">
                <%= submit_tag t("time_entries.entry.split"), class: "btn btn--sm" %>
              <% end %>
            </details>
          <% end %>

          <%= button_to time_entry_path(time_entry), method: :delete, class: "btn btn--danger",
                data: { turbo_confirm: t("time_entries.entry.delete_confirm") } do %>
            <%= icon("trash-2") %>
            <%= t("common.actions.delete") %>
          <% end %>
        </div>
      </details>
    </div>
  </article>
<% end %>
