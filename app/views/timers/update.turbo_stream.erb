<% timer_entry = defined?(@current_timer) ? @current_timer : @time_entry %>

<%# UPDATE (não replace): troca só o CONTEÚDO do frame. Replace do frame inteiro
    punha no lugar o frame "nu" do partial — sem data-turbo-permanent, src e o
    controller timer-bar-sync do layout — quebrando o cronômetro-entre-telas e o
    sync entre abas até o próximo full reload. %>
<%= turbo_stream.update "timer_bar" do %>
  <%= render "timers/bar", time_entry: timer_entry, form_time_entry: @form_time_entry %>
<% end %>

<%= turbo_stream.replace "tracker_entries" do %>
  <%= render "home/tracker_entries", day_groups: @tracker_day_groups %>
<% end %>

<%= turbo_stream.replace "flash" do %>
  <div id="flash"><%= render "shared/flash" %></div>
<% end %>

<%= turbo_stream.replace "command_palette" do %>
  <%= render "layouts/command_palette" %>
<% end %>
