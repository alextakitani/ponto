<% if time_entry %>
  <%# Cápsula viva: um objeto só, denso, fit-content à esquerda da régua.
      A cor do projeto entra como custom property e vira a régua ::before;
      sem projeto, o CSS cai no fallback --color-accent. %>
  <%= tag.div class: "timer-bar timer-bar--running",
        style: ("--project-color: #{time_entry.project.color}" if time_entry.project) do %>

    <div class="timer-bar__clock">
      <span class="timer-bar__live" aria-hidden="true"></span>
      <span class="timer-bar__sr"><%= t("timers.bar.running") %></span>
      <span class="timer-bar__stopwatch tabular-nums" data-controller="stopwatch"
          data-stopwatch-started-at-value="<%= time_entry.started_at.iso8601 %>">
        <%= tracker_duration(0) %>
      </span>
    </div>

    <div class="timer-bar__context">
      <p class="timer-bar__description" title="<%= tracker_entry_description(time_entry) %>"><%= tracker_entry_description(time_entry) %></p>
      <p class="timer-bar__project">
        <% if time_entry.project %>
          <span class="project-dot" style="background-color: <%= time_entry.project.color %>" aria-hidden="true"></span>
        <% end %>
        <span class="timer-bar__project-name"><%= tracker_entry_project_name(time_entry) %></span>
      </p>
    </div>

    <div class="timer-bar__stop">
      <%= button_to timer_path, method: :delete, class: "btn btn--danger" do %>
        <%= icon("square") %>
        <%= t("timers.bar.stop") %>
      <% end %>
    </div>
  <% end %>
<% else %>
  <% form_time_entry ||= TimeEntry.new %>

  <%= form_with url: timer_path, scope: :timer, class: "timer-bar timer-bar--idle" do |form| %>
    <%= hidden_field_tag :page, params[:page] if params[:page].present? %>

    <div class="timer-bar__fields">
      <div class="timer-bar__input">
        <%= form.label :description, t("common.labels.description"), class: "timer-bar__label" %>
        <%= form.text_field :description, value: form_time_entry.description,
              placeholder: t("tracker.description_placeholder") %>
      </div>
    </div>

    <div class="timer-bar__actions">
      <%= form.button type: :submit, class: "btn" do %>
        <%= icon("play") %>
        <%= t("timers.bar.start") %>
      <% end %>
    </div>

    <% if form_time_entry.errors.any? %>
      <p class="timer-bar__error" role="alert"><%= form_time_entry.errors.full_messages.to_sentence %></p>
    <% end %>
  <% end %>
<% end %>
