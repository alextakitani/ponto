<% if time_entry %>
  <%# Cápsula viva: um objeto só, denso, fit-content à esquerda da régua.
      A cor do projeto entra como custom property e vira a régua ::before;
      sem projeto, o CSS cai no fallback --color-accent. %>
  <%# timer-bar--enter: liga a animação de entrada SÓ em render fresco — o
      timer_bar_sync tira a classe no animationend; sem ela, a re-inserção do
      frame permanent na navegação não tem animação pra reiniciar. %>
  <%= tag.div class: "timer-bar timer-bar--running timer-bar--enter",
        style: ("--project-color: #{time_entry.project.color}" if time_entry.project) do %>

    <div class="timer-bar__clock">
      <span class="timer-bar__live" aria-hidden="true"></span>
      <span class="timer-bar__sr"><%= t("timers.bar.running") %></span>
      <span class="timer-bar__stopwatch tabular-nums" data-controller="stopwatch"
          data-stopwatch-started-at-value="<%= time_entry.started_at.iso8601 %>">
        <%= tracker_duration(0) %>
      </span>
    </div>

    <div class="timer-bar__context">
      <p class="timer-bar__description" title="<%= tracker_entry_description(time_entry) %>"><%= tracker_entry_description(time_entry) %></p>
      <p class="timer-bar__project">
        <% if time_entry.project %>
          <span class="project-dot" style="background-color: <%= time_entry.project.color %>" aria-hidden="true"></span>
        <% end %>
        <span class="timer-bar__project-name"><%= tracker_entry_project_name(time_entry) %></span>
      </p>
    </div>

    <div class="timer-bar__stop">
      <%= button_to timer_path, method: :delete, class: "btn btn--danger" do %>
        <%= icon("square") %>
        <span class="timer-bar__stop-label"><%= t("timers.bar.stop") %></span>
      <% end %>
    </div>
  <% end %>
<% else %>
  <% form_time_entry ||= TimeEntry.new %>
  <%# Project padrão pré-selecionado (igual ao form de entry manual): o servidor
      aplica o default só quando a chave `project_id` está AUSENTE (path da API),
      então o form já a envia selecionada para o path web. Re-render com erro
      respeita a escolha do usuário (não re-pre-seleciona). %>
  <% selected_project_id = form_time_entry.project_id || (Current.user.active_default_project&.id unless form_time_entry.errors.any?) %>
  <% selected_project = Current.user.projects.active.find { |project| project.id == selected_project_id.to_i } %>
  <% selected_project_name = selected_project&.name || t("tracker.no_project") %>

  <%= form_with url: timer_path, scope: :timer, class: "timer-bar timer-bar--idle timer-bar--enter" do |form| %>
    <%= hidden_field_tag :page, params[:page] if params[:page].present? %>

    <div class="timer-bar__fields">
      <div class="timer-bar__input">
        <%= form.label :description, t("common.labels.description"), class: "timer-bar__label" %>
        <%= form.text_field :description, value: form_time_entry.description,
              placeholder: t("tracker.description_placeholder") %>
      </div>

      <div class="<%= class_names("timer-bar__select", "timer-bar__select--empty": selected_project.blank?) %>"
           style="<%= "--timer-project-color: #{selected_project.color}" if selected_project %>"
           data-controller="project-select-dot">
        <%= form.label :project_id, t("common.labels.project"), class: "timer-bar__label" %>
        <%= form.hidden_field :project_id, value: selected_project_id, data: { project_select_dot_target: "input" } %>

        <details class="timer-project-picker" data-controller="menu" data-project-select-dot-target="details">
          <summary class="timer-project-picker__summary">
            <span class="timer-project-picker__dot" data-project-select-dot-target="swatch" aria-hidden="true"></span>
            <span class="timer-project-picker__label" data-project-select-dot-target="label"><%= selected_project_name %></span>
          </summary>

          <div class="timer-project-picker__panel">
            <button type="button"
                    class="timer-project-picker__option"
                    data-project-select-dot-id-param=""
                    data-project-select-dot-name-param="<%= t("tracker.no_project") %>"
                    data-project-select-dot-color-param=""
                    data-action="project-select-dot#choose">
              <span class="timer-project-picker__option-label"><%= t("tracker.no_project") %></span>
            </button>

            <% tracker_grouped_projects.each do |client_name, projects| %>
              <div class="timer-project-picker__group">
                <p class="timer-project-picker__group-label"><%= client_name %></p>
                <% projects.each do |project| %>
                  <button type="button"
                          class="<%= class_names("timer-project-picker__option", "timer-project-picker__option--selected": project.id == selected_project_id.to_i) %>"
                          data-project-select-dot-id-param="<%= project.id %>"
                          data-project-select-dot-name-param="<%= project.name %>"
                          data-project-select-dot-color-param="<%= project.color %>"
                          data-action="project-select-dot#choose">
                    <span class="project-dot" style="background-color: <%= project.color %>" aria-hidden="true"></span>
                    <span class="timer-project-picker__option-label"><%= project.name %></span>
                  </button>
                <% end %>
              </div>
            <% end %>
          </div>
        </details>
      </div>

      <%= render "time_entries/tags_fields", form:, time_entry: form_time_entry, scope: "timer" %>
    </div>

    <div class="timer-bar__actions">
      <%= form.button type: :submit, class: "btn timer-bar__start", aria: { label: t("timers.bar.start") } do %>
        <%= icon("play") %>
        <span class="timer-bar__start-label"><%= t("timers.bar.start") %></span>
      <% end %>
    </div>

    <% if form_time_entry.errors.any? %>
      <p class="timer-bar__error" role="alert"><%= form_time_entry.errors.full_messages.to_sentence %></p>
    <% end %>
  <% end %>
<% end %>
