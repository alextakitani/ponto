<%# Barras por DIA (Q6/Q21): uma barra por dia do período, altura = horas do dia.
    Materializa a Q6 (o corte de dia no fuso do user). SVG-livre: divs com height %
    (server-rendered, zero JS). Dias sem entry = barra vazia (o eixo é o período).

    Estilo Clockify: eixo Y de horas à esquerda com linhas de grade; datas embaixo
    só nas segundas (início da semana) pra não empilhar ~30 rótulos num mês. As horas
    do dia vivem no tooltip (title) de cada barra — o eixo dá a escala. %>
<% peak = daily_series.map(&:duration_seconds).max.to_i %>
<% axis = report_bar_axis(peak) %>
<figure class="report-bars" aria-label="<%= t("reports.bars.aria") %>">
  <div class="report-bars__plot">
    <%# Eixo Y: rótulos de hora + linha de grade em cada tick (posicionados por bottom %). %>
    <div class="report-bars__axis" aria-hidden="true">
      <% axis[:ticks].each do |tick| %>
        <div class="report-bars__gridline" style="bottom: <%= tick[:percent] %>%">
          <span class="report-bars__axis-label"><%= report_axis_hours(tick[:hours]) %></span>
        </div>
      <% end %>
    </div>

    <div class="report-bars__track">
      <% daily_series.each do |bucket| %>
        <%# Sáb/dom em cor própria (--color-weekend) pra saltar aos olhos (07/07). %>
        <% col_classes = class_names("report-bars__col", "report-bars__col--weekend": bucket.date.on_weekend?) %>
        <% if bucket.duration_seconds.positive? %>
          <%# data-action: o report_day_controller troca o pulo da âncora por scroll
              suave + destaque (barra e linhas do dia). O href segue funcional sem JS. %>
          <%= link_to "##{report_day_anchor_id(bucket.date)}",
                class: col_classes,
                title: report_bar_title(bucket),
                aria: { label: report_bar_title(bucket) },
                data: { action: "report-day#select", report_day_date_param: bucket.date.iso8601 } do %>
            <div class="report-bars__bar" style="height: <%= report_bar_height(bucket, axis[:max_seconds]) %>%"></div>
          <% end %>
        <% else %>
          <div class="<%= col_classes %>" title="<%= report_bar_title(bucket) %>">
            <div class="report-bars__bar" style="height: <%= report_bar_height(bucket, axis[:max_seconds]) %>%"></div>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>

  <%# Datas nas segundas (início da semana) + SEMPRE o 1º dia do período (a borda
      esquerda) — senão a borda fica sem marca quando o mês não começa na segunda.
      Alinhadas sob as colunas (mesma grade flex do track). %>
  <div class="report-bars__dates" aria-hidden="true">
    <% daily_series.each_with_index do |bucket, index| %>
      <div class="report-bars__date">
        <% if index.zero? || bucket.date.monday? %><%= l(bucket.date, format: :bar_day) %><% end %>
      </div>
    <% end %>
  </div>
</figure>
