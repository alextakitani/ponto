<% content_for :title, t(".title") %>

<header class="report-header">
  <div class="report-header__title">
    <div>
      <h1><%= t(".title") %></h1>
      <p class="muted"><%= t(".lede") %></p>
    </div>

    <%# Exportar (Fatia 5.2): menu ⋮-style com .xlsx / .csv, herdando o recorte atual da
        URL (período/filtros/rounding — Q58). O <details> funciona sem JS; o menu_controller
        só faz o light-dismiss. Datas reais e números somáveis moram no arquivo (Q19/Q20). %>
    <details class="row-menu" data-controller="menu">
      <summary class="btn btn--sm">
        <%= icon("download") %>
        <%= t(".export") %>
      </summary>
      <div class="row-menu__items">
        <%# Turbo Frame: trocar o idioma do export re-renderiza SÓ este frame (o
            PreferencesController volta pro return_to = /reports; o Turbo extrai o
            frame de mesmo id de lá). O <details> fica FORA do frame → o popup de
            export NÃO fecha ao trocar o idioma. Persiste User.export_locale de
            quebra (é um PATCH real, CSRF automático — sem fetch/JS extra). %>
        <%= turbo_frame_tag "export_options" do %>
          <%= render "reports/export_options" %>
        <% end %>
      </div>
    </details>
  </div>

  <div class="report-header__controls">
    <%# Barra de período: setas ‹ › + presets + custom (Q53). GET pra que tudo viaje na URL. %>
    <%= render "reports/period_bar", period: @period %>

    <%# Filtros finos (Q54): dimensões multi-select + billable + description. %>
    <%= render "reports/filters", report: @report, filter_options: @filter_options %>
  </div>

  <%# Métricas do topo (Q21): Total · Faturável · Amount por moeda (Q43). %>
  <section class="report-metrics" aria-label="<%= t("reports.metrics.aria") %>">
    <div class="report-metric">
      <span class="report-metric__label muted"><%= t("reports.metrics.total") %></span>
      <span class="report-metric__value tabular-nums" data-total="duration"><%= report_duration(@report.totals.duration_seconds) %></span>
    </div>
    <div class="report-metric">
      <span class="report-metric__label muted"><%= t("common.labels.billable") %></span>
      <span class="report-metric__value tabular-nums" data-total="billable"><%= report_duration(@report.totals.billable_seconds) %></span>
    </div>
    <div class="report-metric">
      <span class="report-metric__label muted"><%= t("common.labels.amount") %></span>
      <span class="report-metric__value tabular-nums" data-total="amount"><%= report_amounts(@report.totals.amounts) %></span>
    </div>
  </section>
</header>

<%# Página única (07/07): resumo em cima, detalhado embaixo. Período vazio ganha UM
    empty-state aqui — os partials assumem rows presentes (senão empilharia dois). %>
<% if @report.rows.any? %>
  <%# Wrapper do report_day_controller: precisa enxergar o gráfico de barras (no
      Summary) E a tabela Detailed pra sincronizar destaque barra ↔ linhas do dia. %>
  <div data-controller="report-day">
    <section class="report-section" aria-labelledby="report-summary-title">
      <h2 id="report-summary-title"><%= t("reports.sections.summary") %></h2>
      <%= render "reports/summary", report: @report, group_by: @report.group_by %>
    </section>

    <section class="report-section" aria-labelledby="report-detailed-title">
      <h2 id="report-detailed-title"><%= t("reports.sections.detailed") %></h2>
      <%= render "reports/detailed", report: @report %>
    </section>
  </div>
<% else %>
  <div class="empty-state">
    <%= icon("chart-column", size: 40) %>
    <h2><%= t("reports.empty.title") %></h2>
    <p class="muted"><%= t("reports.empty.description") %></p>
  </div>
<% end %>
