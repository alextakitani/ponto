<% content_for :title, t(".title") %>

<header class="page-header">
  <div>
    <h1><%= t(".title") %></h1>
    <p class="muted"><%= t(".lede") %></p>
  </div>

  <%# Exportar (Fatia 5.2): menu ⋮-style com .xlsx / .csv, herdando o recorte atual da
      URL (período/filtros/rounding — Q58). O <details> funciona sem JS; o menu_controller
      só faz o light-dismiss. Datas reais e números somáveis moram no arquivo (Q19/Q20). %>
  <details class="row-menu" data-controller="menu">
    <summary class="btn">
      <%= icon("download") %>
      <%= t(".export") %>
    </summary>
    <div class="row-menu__items">
      <%# turbo: false — download de arquivo é navegação real, não visita Turbo Drive
          (senão o Turbo tentaria renderizar os bytes do xlsx/csv como HTML). %>
      <%= link_to report_export_url(format: :xlsx), class: "btn btn--quiet", data: { turbo: false } do %>
        <%= icon("download") %>
        Excel (.xlsx)
      <% end %>
      <%= link_to report_export_url(format: :csv), class: "btn btn--quiet", data: { turbo: false } do %>
        <%= icon("download") %>
        CSV
      <% end %>
    </div>
  </details>
</header>

<%# Barra de período: setas ‹ › + presets + custom (Q53). GET pra que tudo viaje na URL. %>
<%= render "reports/period_bar", period: @period, view: @view %>

<%# Filtros finos (Q54): dimensões multi-select + billable + description. %>
<%= render "reports/filters", report: @report, filter_options: @filter_options, view: @view %>

<%# Métricas do topo (Q21): Total · Faturável · Amount por moeda (Q43). %>
<section class="report-metrics" aria-label="<%= t("reports.metrics.aria") %>">
  <div class="report-metric">
    <span class="report-metric__label muted"><%= t("reports.metrics.total") %></span>
    <span class="report-metric__value tabular-nums" data-total="duration"><%= report_duration(@report.totals.duration_seconds) %></span>
  </div>
  <div class="report-metric">
    <span class="report-metric__label muted"><%= t("common.labels.billable") %></span>
    <span class="report-metric__value tabular-nums" data-total="billable"><%= report_duration(@report.totals.billable_seconds) %></span>
  </div>
  <div class="report-metric">
    <span class="report-metric__label muted"><%= t("common.labels.amount") %></span>
    <span class="report-metric__value tabular-nums" data-total="amount"><%= report_amounts(@report.totals.amounts) %></span>
  </div>
</section>

<%# Abas Summary/Detailed (Q55): trocam via param `view`, preservando o resto da URL. %>
<nav class="report-tabs" aria-label="<%= t("reports.tabs.aria") %>">
  <%= link_to t("reports.tabs.summary"), report_url(view: "summary"),
        class: class_names("report-tab", "report-tab--active": @view == "summary"),
        data: { report_tab: "summary" } %>
  <%= link_to t("reports.tabs.detailed"), report_url(view: "detailed"),
        class: class_names("report-tab", "report-tab--active": @view == "detailed"),
        data: { report_tab: "detailed" } %>
</nav>

<% if @view == "detailed" %>
  <%= render "reports/detailed", report: @report %>
<% else %>
  <%= render "reports/summary", report: @report, group_by: @report.group_by %>
<% end %>
