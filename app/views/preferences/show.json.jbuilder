# Preferências do usuário autenticado (Q73/07/2026) — contrato da extensão/CLI pra
# espelhar a config sem tela dedicada. Só escalares. Valores possíveis:
# locale ∈ {null, "pt-BR", "en"}; theme ∈ {"system", "light", "dark"}.
json.locale        Current.user.locale
json.theme         Current.user.theme
json.accent        Current.user.accent
json.time_zone     Current.user.time_zone
json.export_locale Current.user.export_locale
