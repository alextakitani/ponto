<% content_for :title, t(".title") %>

<header class="page-header">
  <div>
    <h1><%= t(".title") %></h1>
    <p class="muted"><%= t(".lede") %></p>
  </div>
</header>

<div class="preferences-layout">
  <section class="preferences-section" aria-labelledby="profile-heading">
    <div class="preferences-section__header">
      <h2 id="profile-heading"><%= t(".profile.title") %></h2>
      <p class="muted"><%= t(".profile.description") %></p>
    </div>

    <%= form_with model: @user, url: preferences_path, method: :patch, class: "form-stack" do |form| %>
      <% if @profile_errors.any? %>
        <div class="form-errors">
          <ul>
            <% @profile_errors.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="form-field">
        <%= form.label :name, t(".profile.name") %>
        <%= form.text_field :name, autocomplete: "name" %>
      </div>

      <div class="form-field">
        <label><%= t(".profile.email") %></label>
        <input type="email" value="<%= @user.email %>" disabled>
      </div>

      <div class="form-field">
        <%= form.label :time_zone, t(".profile.time_zone") %>
        <%= form.select :time_zone, @time_zone_options %>
        <p class="form-hint"><%= t(".profile.time_zone_hint") %></p>
      </div>

      <div class="form-field">
        <%= form.label :locale, t(".profile.locale") %>
        <%= form.select :locale, [[t(".profile.locales.auto"), ""], [t(".profile.locales.pt_BR"), "pt-BR"], [t(".profile.locales.en"), "en"]] %>
        <p class="form-hint"><%= t(".profile.locale_hint") %></p>
      </div>

      <div class="form-field">
        <%= form.label :theme, t(".profile.theme") %>
        <%= form.select :theme, [[t(".profile.themes.system"), "system"], [t(".profile.themes.light"), "light"], [t(".profile.themes.dark"), "dark"]] %>
        <p class="form-hint"><%= t(".profile.theme_hint") %></p>
      </div>

      <fieldset class="accent-swatch-field">
        <legend><%= t(".profile.accent") %></legend>
        <p class="form-hint"><%= t(".profile.accent_hint") %></p>

        <div class="accent-swatch-list">
          <% {
            "teal" => "#0d7379",
            "mauve" => "#8839ef",
            "blue" => "#1a5ce0",
            "green" => "#2b7222",
            "peach" => "#b34700",
            "pink" => "#b8368f"
          }.each do |accent, hex| %>
            <%= form.radio_button :accent, accent,
                  class: "accent-swatch__input",
                  aria: { label: t(".profile.accent_aria", accent: t(".profile.accents.#{accent}")) } %>
            <%= tag.label for: "user_accent_#{accent}",
                  class: "accent-swatch__label",
                  style: "--accent-swatch-color: #{hex};",
                  title: t(".profile.accents.#{accent}") do %>
              <span class="accent-swatch__text"><%= t(".profile.accents.#{accent}") %></span>
            <% end %>
          <% end %>
        </div>
      </fieldset>

      <div class="form-actions">
        <%= form.submit t(".profile.submit") %>
      </div>
    <% end %>
  </section>

  <section class="preferences-section" aria-labelledby="tokens-heading">
    <div class="preferences-section__header">
      <h2 id="tokens-heading"><%= t(".tokens.title") %></h2>
      <p class="muted"><%= t(".tokens.description") %></p>
    </div>

    <% if flash[:created_access_token].present? %>
      <div class="token-once" role="status">
        <strong><%= t(".tokens.created") %></strong>
        <code><%= flash[:created_access_token] %></code>
      </div>
    <% end %>

    <%= form_with url: preferences_access_tokens_path, scope: :access_token, class: "form-stack token-form" do |form| %>
      <% if @access_token_errors.any? %>
        <div class="form-errors">
          <ul>
            <% @access_token_errors.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="form-row">
        <div class="form-field">
          <%= form.label :label, t(".tokens.label") %>
          <%= form.text_field :label, placeholder: t(".tokens.label_placeholder") %>
        </div>
        <div class="form-field">
          <%= form.label :permission, t(".tokens.permission") %>
          <%= form.select :permission, [["read", "read"], ["write", "write"]] %>
        </div>
      </div>

      <div class="form-actions">
        <%= form.submit t(".tokens.submit") %>
      </div>
    <% end %>

    <% if @access_tokens.any? %>
      <table class="data-table token-table">
        <thead>
          <tr>
            <th><%= t(".tokens.label") %></th>
            <th><%= t(".tokens.permission") %></th>
            <th><%= t(".tokens.last_used") %></th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @access_tokens.each do |access_token| %>
            <tr>
              <td><%= access_token.label.presence || t(".tokens.no_label") %></td>
              <td><%= access_token.permission %></td>
              <td><%= token_last_used(access_token) %></td>
              <td class="data-table__actions">
                <%= button_to access_token_path(access_token), method: :delete,
                      class: "btn btn--quiet btn--sm",
                      form: { data: { turbo_confirm: t(".tokens.revoke_confirm") } } do %>
                  <%= t(".tokens.revoke") %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="empty-state preferences-empty">
        <p><%= t(".tokens.empty") %></p>
      </div>
    <% end %>
  </section>

  <section class="preferences-section" aria-labelledby="data-heading">
    <div class="preferences-section__header">
      <h2 id="data-heading"><%= t(".data.title") %></h2>
      <p class="muted"><%= t(".data.description") %></p>
    </div>

    <div class="form-actions">
      <%= link_to t(".data.export"), account_data_export_path(format: :json), class: "btn btn--quiet" %>

      <% if @user.empty_bubble? %>
        <%= link_to t(".data.import"), new_account_data_import_path, class: "btn btn--quiet" %>
        <%= link_to t(".data.import_clockify"), new_clockify_import_path, class: "btn btn--quiet" %>
      <% end %>
    </div>

    <% if @user.empty_bubble? %>
      <p class="form-hint"><%= t(".data.import_hint") %></p>
    <% else %>
      <p class="form-hint"><%= t(".data.import_unavailable") %></p>
    <% end %>
  </section>

  <section class="preferences-section" aria-labelledby="install-heading" data-controller="pwa-install">
    <div class="preferences-section__header">
      <h2 id="install-heading"><%= t(".install.title") %></h2>
      <p class="muted"><%= t(".install.description") %></p>
    </div>

    <div class="form-actions">
      <button type="button" class="btn btn--quiet" data-pwa-install-target="button" data-action="pwa-install#install" hidden><%= t(".install.action") %></button>
    </div>

    <p class="form-hint pwa-install-ios" data-pwa-install-target="iosHint" hidden><%= t(".install.ios_hint_html") %></p>
    <p class="form-hint" data-pwa-install-target="unavailable"><%= t(".install.unavailable") %></p>
  </section>
</div>
