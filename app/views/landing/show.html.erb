<% content_for :title, t("landing.meta.title") %>
<% content_for :description, t("landing.meta.description") %>

<div class="lp">
  <%# ── Cabeçalho: marca + acessos secundários (GitHub, entrar) + idioma ── %>
  <header class="lp-head">
    <a class="lp-head__brand" href="#topo">
<%= render "shared/logo_mark", size: 64, css_class: "lp-mark" %>Ponto
    </a>
    <nav class="lp-head__nav" aria-label="<%= t("landing.nav.links_label") %>">
      <%= render "shared/locale_switcher" %>
      <%= link_to t("landing.nav.github"), "https://github.com/alextakitani/ponto", class: "lp-head__link" %>
      <%= link_to t("landing.nav.sign_in"), sign_in_path, class: "lp-head__link" %>
    </nav>
  </header>

  <main id="topo">
    <%# ═══════════════ HERO ═══════════════ %>
    <section class="lp-hero">
      <div class="lp-hero__pitch">
        <p class="lp-eyebrow"><%= t("landing.hero.eyebrow") %></p>
        <h1 class="lp-hero__title">
          <%= t("landing.hero.title_html") %>
        </h1>
        <p class="lp-hero__lede">
          <%= t("landing.hero.lede") %>
        </p>

        <%# Contrato testado preservado: form "pedir acesso" (POST /access_requests)
            OU o aviso de operador (Q38), ancorado em #acesso. %>
        <div id="acesso" class="lp-cta">
          <% if @operator_setup_needed %>
            <%= render "shared/bootstrap_notice", css_class: "lp-notice" %>
          <% else %>
            <p class="lp-cta__label">
              <%= t("landing.cloud.pitch_html") %>
            </p>
            <%= render "access_requests/form" %>
          <% end %>
        </div>
      </div>

      <%# ── Assinatura: mockup do tracker com o timer CORRENDO (produto = tese) ──
          Overdrive (lp-live): o cronômetro tica de verdade e os valores contam de
          0 ao total quando o mockup entra na viewport. SSR mostra os valores finais
          (fallback estático + reduced-motion). %>
      <div class="lp-shot" aria-hidden="true"
          data-controller="lp-live" data-lp-live-start-value="01:47:12">
        <div class="lp-app">
          <div class="lp-app__bar">
            <span class="lp-app__dot lp-app__dot--live"></span>
            <div class="lp-app__field">
              <span class="lp-app__proj"><span class="lp-swatch lp-swatch--a"></span><%= t("landing.mockups.tracker.project_a") %></span>
              <span class="lp-app__desc"><%= t("landing.mockups.tracker.desc_running") %></span>
            </div>
            <span class="lp-clock tabular-nums" data-lp-live-target="clock">01:47:12</span>
            <button class="lp-app__stop" type="button" tabindex="-1"><%= t("landing.mockups.tracker.stop") %></button>
          </div>

          <ul class="lp-app__list">
            <li class="lp-row">
              <span class="lp-row__proj"><span class="lp-swatch lp-swatch--a"></span><%= t("landing.mockups.tracker.project_a") %></span>
              <span class="lp-row__desc muted"><%= t("landing.mockups.tracker.desc_cert") %></span>
              <span class="lp-row__dur tabular-nums">2:10:00</span>
              <span class="lp-row__amt tabular-nums" data-lp-live-target="amount">R$&nbsp;260,00</span>
            </li>
            <li class="lp-row">
              <span class="lp-row__proj"><span class="lp-swatch lp-swatch--b"></span><%= t("landing.mockups.tracker.project_b") %></span>
              <span class="lp-row__desc muted"><%= t("landing.mockups.tracker.desc_review") %></span>
              <span class="lp-row__dur tabular-nums">0:45:00</span>
              <span class="lp-row__amt tabular-nums" data-lp-live-target="amount">€&nbsp;60,00</span>
            </li>
            <li class="lp-row">
              <span class="lp-row__proj"><span class="lp-swatch lp-swatch--c"></span><%= t("landing.mockups.tracker.project_c") %></span>
              <span class="lp-row__desc muted"><%= t("landing.mockups.tracker.desc_scope") %></span>
              <span class="lp-row__dur tabular-nums">1:00:00</span>
              <span class="lp-row__amt tabular-nums" data-lp-live-target="amount">R$&nbsp;180,00</span>
            </li>
          </ul>
        </div>
      </div>
    </section>

    <%# ── Régua de tiques: a assinatura tipográfica (eixo de horas do dia) ──
        Overdrive: um marcador de "agora" (acento) varre a régua devagar — o dia
        passando. CSS puro; reduced-motion o deixa parado no ponto atual. %>
    <div class="lp-ruler" aria-hidden="true">
      <span class="lp-ruler__now"></span>
      <% %w[08 09 10 11 12 13 14 15 16 17 18].each do |h| %>
        <span class="lp-ruler__tick"><span class="lp-ruler__label tabular-nums"><%= h %></span></span>
      <% end %>
    </div>

    <%# ═══════════════ TRÊS PROVAS (mockups reais) ═══════════════ %>
    <section class="lp-section" aria-labelledby="prova-h">
      <h2 id="prova-h" class="lp-section__title"><%= t("landing.proofs.heading") %></h2>
      <p class="lp-section__sub muted">
        <%= t("landing.proofs.sub_html") %>
      </p>

      <div class="lp-proofs">
        <%# 1. Relatório: donut por projeto + barras por dia (SVG inline, theme-aware) %>
        <article class="lp-proof">
          <div class="lp-proof__art" aria-hidden="true">
            <div class="lp-report">
              <svg class="lp-donut" viewBox="0 0 42 42">
                <circle class="lp-donut__track" cx="21" cy="21" r="15.9155"></circle>
                <circle class="lp-donut__seg lp-donut__seg--a" cx="21" cy="21" r="15.9155"
                        stroke-dasharray="48 52" stroke-dashoffset="25"></circle>
                <circle class="lp-donut__seg lp-donut__seg--b" cx="21" cy="21" r="15.9155"
                        stroke-dasharray="31 69" stroke-dashoffset="77"></circle>
                <circle class="lp-donut__seg lp-donut__seg--c" cx="21" cy="21" r="15.9155"
                        stroke-dasharray="21 79" stroke-dashoffset="46"></circle>
              </svg>
              <div class="lp-bars">
                <% [40, 65, 30, 80, 55, 70, 20].each do |h| %>
                  <span class="lp-bars__bar" style="height: <%= h %>%"></span>
                <% end %>
              </div>
            </div>
          </div>
          <h3 class="lp-proof__title"><%= t("landing.proofs.reports.title") %></h3>
          <p class="lp-proof__text muted">
            <%= t("landing.proofs.reports.text_html") %>
          </p>
        </article>

        <%# 2. Popup da extensão de Chrome %>
        <article class="lp-proof">
          <div class="lp-proof__art" aria-hidden="true">
            <div class="lp-popup">
              <div class="lp-popup__head">
                <%= render "shared/logo_mark", size: 16, css_class: "lp-mark lp-mark--sm" %>
                <span class="lp-popup__title"><%= t("landing.mockups.extension.title") %></span>
              </div>
              <div class="lp-popup__timer">
                <span class="lp-swatch lp-swatch--b"></span>
                <span class="lp-popup__proj"><%= t("landing.mockups.extension.project") %></span>
                <span class="lp-clock lp-clock--sm tabular-nums">00:24:08</span>
              </div>
              <button class="lp-popup__btn" type="button" tabindex="-1"><%= t("landing.mockups.extension.stop") %></button>
            </div>
          </div>
          <h3 class="lp-proof__title">
            <%= t("landing.proofs.extension.title") %> <span class="lp-badge"><%= t("landing.proofs.extension.badge") %></span>
          </h3>
          <p class="lp-proof__text muted">
            <%= t("landing.proofs.extension.text") %>
          </p>
        </article>

        <%# 3. Terminal do CLI (comandos reais) %>
        <article class="lp-proof">
          <div class="lp-proof__art" aria-hidden="true">
            <div class="lp-term">
              <div class="lp-term__bar">
                <span class="lp-term__tl"></span><span class="lp-term__tl"></span><span class="lp-term__tl"></span>
              </div>
              <pre class="lp-term__body"><span class="lp-term__ps">$</span> <%= t("landing.mockups.terminal.cmd1") %>
<span class="lp-term__ok"><%= t("landing.mockups.terminal.status") %></span><%= t("landing.mockups.terminal.result1") %>
<span class="lp-term__ps">$</span> <%= t("landing.mockups.terminal.cmd2") %>
<%= t("landing.mockups.terminal.out2") %></pre>
            </div>
          </div>
          <h3 class="lp-proof__title">
            <%= t("landing.proofs.cli.title") %> <code>ponto</code> <span class="lp-badge"><%= t("landing.proofs.cli.badge") %></span>
          </h3>
          <p class="lp-proof__text muted">
            <%= t("landing.proofs.cli.text") %>
          </p>
        </article>
      </div>
    </section>

    <%# ═══════════════ RATE CONGELADA ═══════════════ %>
    <section class="lp-section lp-frozen" aria-labelledby="frozen-h">
      <div class="lp-frozen__copy">
        <h2 id="frozen-h" class="lp-section__title"><%= t("landing.frozen.heading") %></h2>
        <p class="lp-section__sub muted">
          <%= t("landing.frozen.sub") %>
        </p>
      </div>
      <div class="lp-frozen__proof" aria-hidden="true">
        <div class="lp-freeze-row">
          <span class="lp-freeze-row__when tabular-nums">jan</span>
          <span class="lp-freeze-row__rate tabular-nums">R$&nbsp;120,00/h</span>
          <span class="lp-lock" title="<%= t("landing.frozen.lock_title") %>">🔒</span>
        </div>
        <div class="lp-freeze-row">
          <span class="lp-freeze-row__when tabular-nums">jun</span>
          <span class="lp-freeze-row__rate tabular-nums">R$&nbsp;150,00/h</span>
          <span class="lp-freeze-row__now"><%= t("landing.frozen.now") %></span>
        </div>
      </div>
    </section>

    <%# ═══════════════ SELF-HOST (didático e honesto) ═══════════════ %>
    <section class="lp-section" aria-labelledby="host-h">
      <h2 id="host-h" class="lp-section__title"><%= t("landing.host.heading") %></h2>
      <p class="lp-section__sub muted">
        <%= t("landing.host.sub_html", readme_link: link_to(t("landing.host.readme"), "https://github.com/alextakitani/ponto#readme")) %>
      </p>

      <ol class="lp-steps">
        <li class="lp-step">
          <span class="lp-step__n tabular-nums">1</span>
          <div>
            <h3 class="lp-step__title"><%= t("landing.host.steps.clone.title") %></h3>
            <p class="lp-step__text muted">
              <%= t("landing.host.steps.clone.text_html") %>
            </p>
          </div>
        </li>
        <li class="lp-step">
          <span class="lp-step__n tabular-nums">2</span>
          <div>
            <h3 class="lp-step__title"><%= t("landing.host.steps.deploy.title") %></h3>
            <p class="lp-step__text muted">
              <%= t("landing.host.steps.deploy.text_html") %>
            </p>
          </div>
        </li>
        <li class="lp-step">
          <span class="lp-step__n tabular-nums">3</span>
          <div>
            <h3 class="lp-step__title"><%= t("landing.host.steps.configure.title_html") %></h3>
            <p class="lp-step__text muted">
              <%= t("landing.host.steps.configure.text") %>
            </p>
          </div>
        </li>
        <li class="lp-step">
          <span class="lp-step__n tabular-nums">4</span>
          <div>
            <h3 class="lp-step__title"><%= t("landing.host.steps.bootstrap.title") %></h3>
            <p class="lp-step__text muted">
              <%= t("landing.host.steps.bootstrap.text_html") %>
            </p>
          </div>
        </li>
      </ol>
    </section>

    <%# ═══════════════ STACK (argumento self-hoster) ═══════════════ %>
    <section class="lp-section lp-stack" aria-labelledby="stack-h">
      <h2 id="stack-h" class="lp-section__title"><%= t("landing.stack.heading") %></h2>
      <ul class="lp-facts">
        <li class="lp-fact">
          <span class="lp-fact__k"><%= t("landing.stack.backup.key") %></span>
          <span class="lp-fact__v muted"><%= t("landing.stack.backup.value_html") %></span>
        </li>
        <li class="lp-fact">
          <span class="lp-fact__k"><%= t("landing.stack.no_node.key") %></span>
          <span class="lp-fact__v muted"><%= t("landing.stack.no_node.value") %></span>
        </li>
        <li class="lp-fact">
          <span class="lp-fact__k"><%= t("landing.stack.your_data.key") %></span>
          <span class="lp-fact__v muted"><%= t("landing.stack.your_data.value") %></span>
        </li>
        <li class="lp-fact">
          <span class="lp-fact__k"><%= t("landing.stack.portability.key") %></span>
          <span class="lp-fact__v muted"><%= t("landing.stack.portability.value") %></span>
        </li>
        <li class="lp-fact">
          <span class="lp-fact__k"><%= t("landing.stack.open_source.key") %></span>
          <span class="lp-fact__v muted"><%= t("landing.stack.open_source.value_html", github_link: link_to(t("landing.stack.open_source.github_link"), "https://github.com/alextakitani/ponto")) %></span>
        </li>
        <li class="lp-fact">
          <span class="lp-fact__k"><%= t("landing.stack.multiuser.key") %></span>
          <span class="lp-fact__v muted"><%= t("landing.stack.multiuser.value") %></span>
        </li>
      </ul>
    </section>

    <%# ═══════════════ CTA FINAL ═══════════════ %>
    <section class="lp-section lp-final" aria-labelledby="final-h">
      <%# copy embrulhado num wrapper fit-content: o div encolhe pra largura do
          TÍTULO (o filho mais largo), e o sub herda essa largura exata — sem
          max-width chutado. %>
      <div class="lp-final__copy">
        <h2 id="final-h" class="lp-section__title"><%= t("landing.final.heading") %></h2>
        <p class="lp-section__sub muted">
          <%= t("landing.final.sub_html", github_link: link_to(t("landing.final.github_link"), "https://github.com/alextakitani/ponto")) %>
        </p>
      </div>
      <div class="lp-final__cta">
        <% if @operator_setup_needed %>
          <%= render "shared/bootstrap_notice", css_class: "lp-notice" %>
        <% else %>
          <%= render "access_requests/form" %>
          <p class="lp-final__signin muted">
            <%= t("landing.final.signin_prompt") %> <%= link_to t("landing.nav.sign_in"), sign_in_path %>
          </p>
        <% end %>
      </div>
    </section>
  </main>

  <footer class="lp-foot">
    <%# Nota do asterisco do preço promocional (Ponto Cloud US$ 1/mês). %>
    <p class="lp-foot__note muted"><%= t("landing.footer.promo_note") %></p>
    <div class="lp-foot__bar">
      <span class="lp-foot__brand"><%= render "shared/logo_mark", size: 28, css_class: "lp-mark lp-mark--sm" %>Ponto</span>
      <nav class="lp-foot__nav" aria-label="<%= t("landing.footer.nav_label") %>">
        <%= render "shared/locale_switcher" %>
        <%= link_to t("landing.nav.github"), "https://github.com/alextakitani/ponto" %>
        <%= link_to t("landing.nav.sign_in"), sign_in_path %>
      </nav>
    </div>
  </footer>
</div>
