<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <title><%= content_for(:title) || "Ponto" %></title>
    <meta name="description" content="<%= content_for(:description) || "Ponto — time tracker self-hosted" %>">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Ponto">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Ordem de cascata explícita: tokens (custom properties) → base → forms. %>
    <%= stylesheet_link_tag "tokens", "base", "forms", "landing", "admin", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <%# Container do flash com id fixo pra que respostas Turbo Stream possam
        atualizá-lo (ex.: aprovar/recusar pedido no painel de admin). %>
    <div id="flash"><%= render "shared/flash" %></div>
    <%= yield %>
  </body>
</html>
