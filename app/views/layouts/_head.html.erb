<%# <head> comum aos dois layouts (application = auth/landing; app = shell interno).
    Título/meta/CSS/importmap num lugar só, sem duplicação. %>
<title><%= content_for(:title) || "Ponto" %></title>
<meta name="description" content="<%= content_for(:description) || "Ponto — time tracker self-hosted" %>">
<meta name="viewport" content="width=device-width,initial-scale=1">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="application-name" content="Ponto">
<meta name="mobile-web-app-capable" content="yes">
<%= csrf_meta_tags %>
<%= csp_meta_tag %>

<%= yield :head %>

<%# Manifest da PWA (rota já existe em config/routes.rb; ícones reais agora em public/). %>
<%= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

<%# Favicons: SVG (moderno, versão simplificada p/ legibilidade em tamanho mínimo) →
    .ico multi-size (16/32/48, fallback legado). apple-touch = PNG 180 dedicado. %>
<link rel="icon" href="/favicon.svg" type="image/svg+xml">
<link rel="icon" href="/favicon.ico" sizes="16x16 32x32 48x48">
<link rel="apple-touch-icon" href="/apple-touch-icon.png">

<%# Ordem de cascata explícita: tokens (custom properties) → base → forms → catalog
    (componentes genéricos das telas) → específicos de cada tela. %>
<%= stylesheet_link_tag "tokens", "base", "forms", "catalog", "landing", "admin", "shell", "projects", "data-turbo-track": "reload" %>
<%= javascript_importmap_tags %>
