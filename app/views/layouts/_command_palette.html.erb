<div id="command_palette">
  <dialog class="command-palette" data-command-palette-target="dialog">
    <div class="command-palette__panel">
      <%# Header com a borda-assinatura de acento (mesma do topo do app) + fechar
          explícito — Esc e clique fora continuam funcionando (pedido do dono 07/07). %>
      <header class="command-palette__header">
        <span class="command-palette__title"><%= t("shell.command.title") %></span>
        <button type="button" class="command-palette__close"
            aria-label="<%= t("shell.command.close") %>"
            data-action="command-palette#close">
          <%= icon("x") %>
        </button>
      </header>
      <label class="command-palette__label" for="command_palette_query"><%= t("shell.command.search_label") %></label>
      <input id="command_palette_query"
          class="command-palette__search"
          type="search"
          autocomplete="off"
          placeholder="<%= t("shell.command.placeholder") %>"
          role="combobox"
          aria-controls="command_palette_list"
          aria-expanded="false"
          aria-autocomplete="list"
          data-command-palette-target="input"
          data-action="input->command-palette#filter keydown->command-palette#handleListKeydown">

      <p class="command-palette__status" role="status"
          data-command-palette-target="status"
          data-empty-message="<%= t("shell.command.empty") %>"></p>

      <div id="command_palette_list" class="command-palette__groups" role="listbox" data-command-palette-target="list">
        <section class="command-palette__group" data-command-palette-target="group" role="presentation">
          <h2><%= t("shell.command.groups.timer") %></h2>
          <% if command_palette_current_timer %>
            <%= button_to timer_path, method: :delete,
                  class: "command-palette__item",
                  id: "command_palette_item_timer_stop",
                  role: "option",
                  aria: { selected: false },
                  params: (params[:page].present? ? { page: params[:page] } : {}),
                  data: { command_palette_target: "item", command_palette_label: t("shell.command.search_terms.stop_timer") } do %>
              <span><%= t("shell.command.timer.stop") %></span>
              <small><%= t("shell.command.timer.stop_hint") %></small>
            <% end %>
          <% else %>
            <button type="button"
                id="command_palette_item_timer_start"
                role="option"
                aria-selected="false"
                class="command-palette__item"
                data-command-palette-target="item"
                data-command-palette-label="<%= t("shell.command.search_terms.start_timer") %>"
                data-action="command-palette#focusTimer">
              <span><%= t("shell.command.timer.start") %></span>
              <small><%= t("shell.command.timer.start_hint") %></small>
            </button>
          <% end %>
        </section>

        <section class="command-palette__group" data-command-palette-target="group" role="presentation">
          <h2><%= t("shell.command.groups.navigation") %></h2>
          <%= link_to home_path, class: "command-palette__item",
                id: "command_palette_item_nav_tracker",
                role: "option",
                aria: { selected: false },
                data: { command_palette_target: "item", command_palette_label: t("shell.command.search_terms.nav_tracker") } do %>
            <span><%= t("shell.nav.tracker") %></span>
            <small><%= t("shell.command.navigation.tracker") %></small>
          <% end %>
          <%= link_to reports_path, class: "command-palette__item",
                id: "command_palette_item_nav_reports",
                role: "option",
                aria: { selected: false },
                data: { command_palette_target: "item", command_palette_label: t("shell.command.search_terms.nav_reports") } do %>
            <span><%= t("shell.nav.reports") %></span>
            <small><%= t("shell.command.navigation.reports") %></small>
          <% end %>
          <%= link_to projects_path, class: "command-palette__item",
                id: "command_palette_item_nav_projects",
                role: "option",
                aria: { selected: false },
                data: { command_palette_target: "item", command_palette_label: t("shell.command.search_terms.nav_projects") } do %>
            <span><%= t("shell.nav.projects") %></span>
            <small><%= t("shell.command.navigation.projects") %></small>
          <% end %>
          <%= link_to clients_path, class: "command-palette__item",
                id: "command_palette_item_nav_clients",
                role: "option",
                aria: { selected: false },
                data: { command_palette_target: "item", command_palette_label: t("shell.command.search_terms.nav_clients") } do %>
            <span><%= t("shell.nav.clients") %></span>
            <small><%= t("shell.command.navigation.clients") %></small>
          <% end %>
          <%= link_to tags_path, class: "command-palette__item",
                id: "command_palette_item_nav_tags",
                role: "option",
                aria: { selected: false },
                data: { command_palette_target: "item", command_palette_label: t("shell.command.search_terms.nav_tags") } do %>
            <span><%= t("shell.nav.tags") %></span>
            <small><%= t("shell.command.navigation.tags") %></small>
          <% end %>
        </section>

        <% if command_palette_recent_time_entries.any? %>
          <section class="command-palette__group" data-command-palette-target="group" role="presentation">
            <h2><%= t("shell.command.groups.recent") %></h2>
            <% command_palette_recent_time_entries.each do |time_entry| %>
              <%= button_to time_entry_duplicate_path(time_entry),
                    class: "command-palette__item",
                    id: "command_palette_item_recent_#{time_entry.id}",
                    role: "option",
                    aria: { selected: false },
                    params: (params[:page].present? ? { page: params[:page] } : {}),
                    data: {
                      command_palette_target: "item",
                      command_palette_label: "#{tracker_entry_description(time_entry)} #{tracker_entry_project_name(time_entry)}"
                    } do %>
                <span><%= t("shell.command.recent.resume", description: tracker_entry_description(time_entry)) %></span>
                <small>
                  <%# A bolinha do projeto traz a cor legítima do app pra palette
                      (a personalidade vem da cor dos projetos — DESIGN.md). %>
                  <% if time_entry.project %>
                    <span class="project-dot" style="background-color: <%= time_entry.project.color %>" aria-hidden="true"></span>
                  <% end %>
                  <%= tracker_entry_project_name(time_entry) %>
                </small>
              <% end %>
            <% end %>
          </section>
        <% end %>
      </div>
    </div>
  </dialog>
</div>
