<div id="sign_in_form" class="card">
  <h1>Entrar no Ponto</h1>
  <p class="muted">Enviamos um código de 6 dígitos para o seu e-mail.</p>

  <%# Aviso de operador (Q38): sem conta nenhuma e sem ADMIN_EMAIL, não dá pra
      criar o 1º admin. Pedimos a variável de ambiente em vez do fallback perigoso. %>
  <% if User.bootstrap_blocked? %>
    <p class="muted" role="alert">
      Nenhuma conta existe e ADMIN_EMAIL não está configurado — defina a variável
      de ambiente e recarregue.
    </p>
  <% end %>

  <%# Alert genérico (login exigido, rate limit, e-mail em branco): só o texto.
      O shared/_flash ainda não existe nesta branch, então o form mostra o alert
      aqui — mas SEM o link "pedir acesso", que é exclusivo da conta inexistente. %>
  <% if flash[:alert].present? %>
    <p class="muted" role="alert"><%= flash[:alert] %></p>
  <% end %>

  <%# Conta inexistente (Q28): a chave dedicada account_missing puxa o link de
      "pedir acesso" (aponta pra root_path por ora; TODO(Task 1.3): landing). %>
  <% if flash[:account_missing] %>
    <p class="muted"><%= link_to "Pedir acesso", root_path %></p>
  <% end %>

  <%= form_with url: sign_in_path, method: :post do |f| %>
    <%= f.email_field :email,
          required: true,
          autofocus: true,
          autocomplete: "email",
          placeholder: "voce@exemplo.com" %>
    <%= f.submit "Enviar código" %>
  <% end %>
</div>
