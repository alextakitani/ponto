<div id="sign_in_form" class="card">
  <h1><%= t("sessions.code_form.title") %></h1>
  <p class="muted">
    <%= t("sessions.code_form.description_html", email: email_pending_authentication) %>
  </p>

  <% if Rails.env.development? && flash[:sign_in_code].present? %>
    <p class="muted"><%= t("sessions.code_form.dev_code_html", code: flash[:sign_in_code]) %></p>
  <% end %>

  <%= form_with url: sign_in_session_path, method: :post, data: { controller: "code-input" } do |f| %>
    <%# O valor real vai neste campo escondido; as 6 caixas só alimentam ele. %>
    <%= f.hidden_field :code, data: { code_input_target: "hidden" } %>

    <div class="code-boxes" role="group" aria-label="<%= t("sessions.code_form.title") %>">
      <% 6.times do |i| %>
        <input type="text"
               class="code-box"
               inputmode="numeric"
               pattern="[0-9]*"
               maxlength="1"
               autocomplete="<%= i.zero? ? "one-time-code" : "off" %>"
               <%= "autofocus" if i.zero? %>
               aria-label="<%= t("sessions.code_form.digit", position: i + 1) %>"
               data-code-input-target="box"
               data-action="input->code-input#input keydown->code-input#keydown paste->code-input#paste">
      <% end %>
    </div>

    <%= f.submit t("sessions.code_form.submit") %>
  <% end %>

  <p class="muted">
    <%= link_to t("sessions.code_form.use_another_email"), sign_in_path %>
  </p>
</div>
