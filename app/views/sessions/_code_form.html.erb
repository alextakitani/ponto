<div id="sign_in_form" class="card">
  <h1><%= t("sessions.code_form.title") %></h1>
  <p class="muted">
    <%= t("sessions.code_form.description_html", email: email_pending_authentication) %>
  </p>

  <% if Rails.env.development? && flash[:sign_in_code].present? %>
    <p class="muted"><%= t("sessions.code_form.dev_code_html", code: flash[:sign_in_code]) %></p>
  <% end %>

  <%= form_with url: sign_in_session_path, method: :post do |f| %>
    <%= f.text_field :code,
          required: true,
          autofocus: true,
          autocomplete: "one-time-code",
          inputmode: "numeric",
          pattern: "[0-9]*",
          maxlength: 6,
          placeholder: "______" %>
    <%= f.submit t("sessions.code_form.submit") %>
  <% end %>

  <p class="muted">
    <%= link_to t("sessions.code_form.use_another_email"), sign_in_path %>
  </p>
</div>
