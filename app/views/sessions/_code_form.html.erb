<div id="sign_in_form" class="card">
  <h1>Digite o código</h1>
  <p class="muted">
    Enviamos um código de 6 dígitos para <strong><%= email_pending_authentication %></strong>.
    Ele expira em 15 minutos.
  </p>

  <% if Rails.env.development? && flash[:sign_in_code].present? %>
    <p class="muted">Dev: código <strong><%= flash[:sign_in_code] %></strong></p>
  <% end %>

  <%= form_with url: sign_in_session_path, method: :post do |f| %>
    <%= f.text_field :code,
          required: true,
          autofocus: true,
          autocomplete: "one-time-code",
          inputmode: "numeric",
          pattern: "[0-9]*",
          maxlength: 6,
          placeholder: "______" %>
    <%= f.submit "Entrar" %>
  <% end %>

  <p class="muted">
    <%= link_to "Usar outro e-mail", sign_in_path %>
  </p>
</div>
