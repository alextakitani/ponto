<%# Uma linha densa da lista de projetos (TELA 01). Bolinha da cor + nome · cliente ·
    Registrado · rate efetiva (marca herança em muted). Menu ⋮
    (<details> + Stimulus menu_controller p/ fechar ao clicar fora — light-dismiss). %>
<% registered_seconds ||= @registered_seconds || Hash.new(0) %>
<% registered = registered_seconds.fetch(project.id, 0) %>
<tr id="<%= dom_id(project) %>">
  <td>
    <span class="project-dot" style="background-color: <%= project.color %>" aria-hidden="true"></span>
    <%= link_to project.name, edit_project_path(project) %>
    <% if project.id == Current.user.default_project_id %><span class="default-badge"><%= icon("star", size: 12) %><%= t("projects.project.default_badge") %></span><% end %>
    <% if project.archived? %><span class="tag-badge"><%= t("common.archived") %></span><% end %>
  </td>
  <td><%= project.client ? project.client.name : t("common.none") %></td>
  <td class="data-table__num tabular-nums">
    <% if registered.zero? %>
      <span class="muted">0:00</span>
    <% else %>
      <%# title = a soma em anos/meses/dias no mouseover (pedido do dono 07/07). %>
      <span title="<%= project_registered_words(registered) %>"><%= tracker_duration(registered) %></span>
    <% end %>
  </td>
  <td class="data-table__num tabular-nums">
    <%= project_effective_rate(project) %>
    <% if project.rate_inherited? %>
      <span class="muted project-rate-source"><%= t("projects.project.from_client") %></span>
    <% end %>
  </td>
  <td class="data-table__actions">
    <%# Summary = botão compacto sem label visível → aria-label (Q80). %>
    <details class="row-menu" data-controller="menu">
      <summary class="btn btn--quiet" aria-label="<%= t("projects.project.actions_label", name: project.name) %>"><%= icon("ellipsis-vertical") %></summary>
      <div class="row-menu__items">
        <%= link_to edit_project_path(project), class: "btn btn--quiet" do %>
          <%= icon("pencil") %>
          <%= t("common.actions.edit") %>
        <% end %>

        <% if project.archived? %>
          <%= button_to project_archival_path(project), method: :delete, class: "btn btn--quiet" do %>
            <%= icon("archive-restore") %>
            <%= t("common.actions.unarchive") %>
          <% end %>
        <% else %>
          <%= button_to project_archival_path(project), class: "btn btn--quiet" do %>
            <%= icon("archive") %>
            <%= t("common.actions.archive") %>
          <% end %>
        <% end %>

        <% if project.id == Current.user.default_project_id %>
          <%= button_to project_default_path(project), method: :delete, class: "btn btn--quiet" do %>
            <%= icon("star") %>
            <%= t("projects.project.remove_default") %>
          <% end %>
        <% else %>
          <%= button_to project_default_path(project), class: "btn btn--quiet" do %>
            <%= icon("star") %>
            <%= t("projects.project.set_default") %>
          <% end %>
        <% end %>

        <%# Hard-delete com confirmação (Q7). As tasks caem junto; a Fase 3 restringe
            quando houver entries. %>
        <%= button_to project_path(project), method: :delete,
              class: "btn btn--danger",
              data: { turbo_confirm: t("projects.project.delete_confirm", name: project.name) } do %>
          <%= icon("trash-2") %>
          <%= t("common.actions.delete") %>
        <% end %>
      </div>
    </details>
  </td>
</tr>
