<%# Uma linha densa da lista de projetos (TELA 01). Bolinha da cor + nome · cliente ·
    Registrado (placeholder Fase 3) · rate efetiva (marca herança em muted). Menu ⋮
    (<details> + Stimulus menu_controller p/ fechar ao clicar fora — light-dismiss). %>
<tr id="<%= dom_id(project) %>">
  <td>
    <span class="project-dot" style="background-color: <%= project.color %>" aria-hidden="true"></span>
    <%= link_to project.name, edit_project_path(project) %>
    <% if project.archived? %><span class="tag-badge">arquivado</span><% end %>
  </td>
  <td><%= project.client ? project.client.name : "—" %></td>
  <td class="data-table__num tabular-nums">
    <%# TODO Fase 3 (TimeEntry): somar as horas registradas no projeto. Placeholder. %>
    <span class="muted">0:00</span>
  </td>
  <td class="data-table__num tabular-nums">
    <%= project_effective_rate(project) %>
    <% if project.rate_inherited? %>
      <span class="muted project-rate-source">do cliente</span>
    <% end %>
  </td>
  <td class="data-table__actions">
    <details class="row-menu" data-controller="menu">
      <summary class="btn btn--quiet">⋮</summary>
      <div class="row-menu__items">
        <%= link_to "Editar", edit_project_path(project), class: "btn btn--quiet" %>

        <% if project.archived? %>
          <%= button_to "Desarquivar", project_archival_path(project), method: :delete, class: "btn btn--quiet" %>
        <% else %>
          <%= button_to "Arquivar", project_archival_path(project), class: "btn btn--quiet" %>
        <% end %>

        <%# Hard-delete com confirmação (Q7). As tasks caem junto; a Fase 3 restringe
            quando houver entries. %>
        <%= button_to "Deletar", project_path(project), method: :delete,
              class: "btn btn--danger",
              data: { turbo_confirm: "Deletar “#{project.name}” definitivamente? Esta ação não pode ser desfeita." } %>
      </div>
    </details>
  </td>
</tr>
