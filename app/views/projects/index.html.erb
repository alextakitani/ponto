<% content_for :title, t(".title") %>

<header class="page-header">
  <div>
    <h1><%= t(".title") %></h1>
    <p class="muted"><%= t(".lede") %></p>
  </div>
  <%= link_to new_project_path, class: "btn" do %>
    <%= icon("plus") %>
    <%= t(".new") %>
  <% end %>
</header>

<div class="page-toolbar">
  <%# Busca por nome via Nameable.name_matching no SQL. %>
  <%= form_with url: projects_path, method: :get, class: "page-search" do |form| %>
    <%= icon("search") %>
    <% if @showing_archived %><%= form.hidden_field :archived, value: "1" %><% end %>
    <% if params[:client_id].present? %><%= form.hidden_field :client_id, value: params[:client_id] %><% end %>
    <%= form.search_field :q, value: params[:q], placeholder: t("common.search_by_name"),
          autocomplete: "off", "aria-label": t(".search_aria") %>
  <% end %>

  <%# Filtro por cliente (select simples; submete no change via Stimulus-less form). %>
  <%= form_with url: projects_path, method: :get, class: "page-filter", data: { turbo_action: "replace" } do |form| %>
    <% if @showing_archived %><%= form.hidden_field :archived, value: "1" %><% end %>
    <% if params[:q].present? %><%= form.hidden_field :q, value: params[:q] %><% end %>
    <%= form.select :client_id,
          options_for_select(@clients.map { |c| [ c.name, c.id ] }, params[:client_id]),
          { include_blank: t(".all_clients") },
          { onchange: "this.form.requestSubmit()", "aria-label": t(".filter_client_aria") } %>
  <% end %>

  <%# Alterna entre ativos e arquivados (link discreto — Q7). %>
  <% if @showing_archived %>
    <%= link_to t("common.view_active"), projects_path, class: "muted" %>
  <% else %>
    <%= link_to t("common.view_archived"), projects_path(archived: "1"), class: "muted" %>
  <% end %>
</div>

<% if @projects.any? %>
  <table class="data-table">
    <thead>
      <tr>
        <th><%= t("common.labels.project") %></th>
        <th><%= t("common.labels.client") %></th>
        <th class="data-table__num"><%= t("projects.index.registered") %></th>
        <th class="data-table__num"><%= t("common.labels.rate_short") %></th>
        <th></th>
      </tr>
    </thead>
    <tbody id="projects_list">
      <%= render partial: "projects/project", collection: @projects, as: :project %>
    </tbody>
  </table>
<% elsif params[:q].present? %>
  <div class="empty-state">
    <p><%= t(".empty.search", query: params[:q]) %></p>
  </div>
<% elsif @showing_archived %>
  <div class="empty-state">
    <p><%= t(".empty.archived") %></p>
  </div>
<% else %>
  <div class="empty-state">
    <%= icon("folder-open", class: "icon--lg") %>
    <h2><%= t(".empty.title") %></h2>
    <p class="muted">
      <%= t(".empty.description") %>
    </p>
    <%= link_to new_project_path, class: "btn" do %>
      <%= icon("plus") %>
      <%= t(".empty.cta") %>
    <% end %>
  </div>
<% end %>
