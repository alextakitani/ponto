<%# Create inválido: re-renderiza a seção com a task errada no form (reexibe os erros
    inline — colisão de nome, arquivado etc.). %>
<%= turbo_stream.replace "project_tasks" do %>
  <%= turbo_frame_tag "project_tasks" do %>
    <%= render "projects/tasks/section", project: @project, form_task: @task %>
  <% end %>
<% end %>
