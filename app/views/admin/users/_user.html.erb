<%# Uma linha da tabela de contas. É o próprio admin logado? Menu de ações some
    onde não se aplica (auto-deleção, reenviar convite p/ quem já entrou). %>
<tr id="<%= dom_id(user) %>">
  <td>
    <%= user.email %>
    <% if user == current_user %><span class="muted">(você)</span><% end %>
  </td>
  <td><%= user.name %></td>
  <td><%= "sim" if user.admin? %></td>
  <td><%= user_status_label(user) %></td>
  <td class="admin__actions">
    <%# menu_controller: fecha ao clicar fora / Escape (o <details> nativo não faz). %>
    <details class="admin__menu" data-controller="menu">
      <summary class="btn btn--quiet">
        <%= icon("ellipsis-vertical") %>
        Ações
      </summary>
      <div class="admin__menu-items">
        <%# Reenviar convite: só pra convidado (nunca entrou). %>
        <% if user.invited? %>
          <%= button_to admin_user_invitation_path(user), class: "btn btn--quiet" do %>
            <%= icon("mail") %>
            Reenviar convite
          <% end %>
        <% end %>

        <%# Suspender / Reativar (user-minus/user-plus — par mais claro que pause/play
            pra uma AÇÃO sobre conta). %>
        <% if user.suspended? %>
          <%= button_to admin_user_suspension_path(user), method: :delete, class: "btn btn--quiet" do %>
            <%= icon("user-plus") %>
            Reativar
          <% end %>
        <% else %>
          <%= button_to admin_user_suspension_path(user), class: "btn btn--quiet" do %>
            <%= icon("user-minus") %>
            Suspender
          <% end %>
        <% end %>

        <%# Promover / Rebaixar. %>
        <% if user.admin? %>
          <%= button_to admin_user_admin_role_path(user), method: :delete, class: "btn btn--quiet" do %>
            <%= icon("shield-off") %>
            Rebaixar
          <% end %>
        <% else %>
          <%= button_to admin_user_admin_role_path(user), class: "btn btn--quiet" do %>
            <%= icon("shield") %>
            Promover a admin
          <% end %>
        <% end %>

        <%# Deletar: nunca A SI MESMO (a policy também barra). Expande a confirmação
            por digitação do e-mail (Q33), sem JS. %>
        <% if user != current_user %>
          <details class="admin__confirm">
            <summary class="btn btn--danger">
              <%= icon("trash-2") %>
              Deletar…
            </summary>
            <div class="admin__confirm-box">
              <p class="muted">
                Isso apaga a conta e TODOS os dados dela, de forma permanente.
                Exporte os dados antes se precisar — o export estará disponível em breve.
              </p>
              <%= form_with url: admin_user_path(user), method: :delete do |form| %>
                <label class="muted">Para confirmar, digite <strong><%= user.email %></strong>:</label>
                <%= form.text_field :email_confirmation, autocomplete: "off" %>
                <%= form.submit "Deletar definitivamente", class: "btn btn--danger" %>
              <% end %>
            </div>
          </details>
        <% end %>
      </div>
    </details>
  </td>
</tr>
