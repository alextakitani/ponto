<%# Ajustes rápidos na welcome: idioma e tema como <select> nativos (legíveis e
    acessíveis por construção). Cada select submete NO CHANGE via settings_select
    (sem botão), fazendo PATCH /preferences com return_to de volta pra cá. O idioma
    recarrega no novo locale; o tema aplica NA HORA (theme_controller aplica o
    data-theme no body antes do submit) e persiste em paralelo. %>
<section class="quick-settings" data-controller="theme" data-theme-current-value="<%= Current.user.theme %>">
  <div class="quick-settings__group">
    <%= form_with url: preferences_path, method: :patch,
          data: { controller: "settings-select", action: "change->settings-select#submit" } do |form| %>
      <%= form.hidden_field :return_to, value: welcome_path %>
      <%= form.label :locale, t("welcome.quick.language"), class: "quick-settings__label" %>
      <%# O locale muda a URL de retorno (return_to) pra a página recarregar já no idioma novo. %>
      <%= form.select "user[locale]",
            options_for_select(
              [ [ t("preferences.show.profile.locales.pt_BR"), "pt-BR" ], [ t("preferences.show.profile.locales.en"), "en" ] ],
              I18n.locale.to_s
            ),
            {},
            data: { settings_select_target: "localeField" } %>
    <% end %>
  </div>

  <div class="quick-settings__group">
    <%= form_with url: preferences_path, method: :patch,
          data: { controller: "settings-select", action: "change->settings-select#submit" } do |form| %>
      <%= form.hidden_field :return_to, value: welcome_path %>
      <%= form.label :theme, t("welcome.quick.theme"), class: "quick-settings__label" %>
      <%= form.select "user[theme]",
            options_for_select(
              [ [ t("preferences.show.profile.themes.system"), "system" ], [ t("preferences.show.profile.themes.light"), "light" ], [ t("preferences.show.profile.themes.dark"), "dark" ] ],
              Current.user.theme
            ),
            {},
            data: { action: "theme#apply", theme_target: "select" } %>
    <% end %>
  </div>
</section>
