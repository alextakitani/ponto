<%# Form público "pedir acesso" (Q24). E-mail obrigatório; nome e observação opcionais.
    i18n (Q79): labels/botão via t(). Compartilhado com telas PT — como o default é
    pt-BR, elas seguem idênticas. %>
<%# scope: obrigatório — o controller faz params.require(:access_request); sem o
    wrapper os campos vão soltos e o POST morre em ParameterMissing (bug 06/07). %>
<%= form_with scope: :access_request, url: access_requests_path, method: :post, class: "landing__form" do |f| %>
  <div class="field">
    <%= f.label :email, t("access_requests.form.email_label") %>
    <%= f.email_field :email,
          required: true,
          autocomplete: "email",
          placeholder: t("access_requests.form.email_placeholder") %>
  </div>

  <div class="field">
    <%= f.label :name, t("access_requests.form.name_label") %>
    <%= f.text_field :name, autocomplete: "name" %>
  </div>

  <div class="field">
    <%= f.label :note, t("access_requests.form.note_label") %>
    <%= f.text_area :note, rows: 3 %>
  </div>

  <%= f.submit t("access_requests.form.submit") %>
<% end %>
